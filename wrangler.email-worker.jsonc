{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "devlog-email-worker",
  "main": "src/worker/consumer.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "queues": {
    "consumers": [
      {
        "queue": "email-queue",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
      },
    ],
  },
}
